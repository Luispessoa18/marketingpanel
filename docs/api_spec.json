{
  "_info": {
    "title": "Meta Connection Panel – API Spec para uso externo",
    "version": "1.0",
    "base_url": "https://SEU_SERVIDOR",
    "auth_note": "Use o campo 'admin_token' no body dos POSTs que exigem auth. Para GETs protegidos use cookie de sessão (panel_auth). Para tráfego pago e performance use cookies ou passe ig_user_id + access_token no body.",
    "status_legend": {
      "EXISTS": "Rota já existe e funciona",
      "MISSING": "Rota NÃO existe – precisa ser criada",
      "PARTIAL": "Existe mas falta funcionalidade específica"
    }
  },

  "auth": {
    "admin_token": {
      "description": "Token master do sistema. Configurado via env/secrets como META_PANEL_ADMIN_TOKEN.",
      "how_to_use": "Inclua no body do POST: { \"admin_token\": \"SEU_TOKEN\", ... }",
      "routes_that_accept": [
        "POST /meta/instagram-media/create",
        "POST /meta/instagram-media/publish",
        "POST /schedule/post/add"
      ]
    },
    "ig_user_id_plus_access_token": {
      "description": "Para rotas que usam _resolve_ig_context, você pode passar ig_user_id + access_token diretamente no body e o sistema ignora a sessão interna.",
      "how_to_use": "{ \"ig_user_id\": \"123456\", \"access_token\": \"TOKEN_DA_PAGINA\", ... }",
      "routes_that_accept": [
        "POST /meta/instagram/carousel",
        "POST /meta/instagram/story",
        "POST /meta/instagram/reel",
        "POST /meta/instagram/publish-container"
      ]
    },
    "page_id_lookup": {
      "description": "Para rotas de Facebook e Instagram, basta passar o page_id. O sistema busca o access_token internamente na sessão salva.",
      "how_to_use": "{ \"page_id\": \"ID_DA_PAGINA\", ... }",
      "routes_that_accept": [
        "POST /meta/facebook/post",
        "POST /meta/facebook/photo",
        "POST /meta/facebook/album"
      ]
    }
  },

  "oauth": {
    "_note": "Fluxo OAuth Meta/Facebook para conectar páginas e contas de anúncio. Depois do callback, as páginas e ad_accounts ficam salvos no servidor e disponíveis pelos outros endpoints.",
    "endpoints": [
      {
        "status": "EXISTS",
        "method": "GET",
        "path": "/meta/connect/start",
        "description": "Redireciona o usuário para o dialog OAuth do Facebook/Instagram. Solicita todos os escopos de pages + ads + instagram.",
        "auth": "Cookie de sessão do painel (panel_auth)",
        "query_params": {},
        "response": "302 redirect para Facebook OAuth dialog"
      },
      {
        "status": "EXISTS",
        "method": "GET",
        "path": "/meta/connect/callback",
        "description": "Callback OAuth – troca o code pelo access_token, busca páginas e ad_accounts, salva a sessão.",
        "auth": "Nenhuma (chamado pelo Facebook)",
        "query_params": {
          "code": "string – código OAuth retornado pelo Facebook",
          "state": "string – state passado no connect/start",
          "error": "string – erro se o usuário negou permissão"
        },
        "response": "302 redirect para /"
      },
      {
        "status": "EXISTS",
        "method": "GET",
        "path": "/meta/accounts",
        "description": "Lista as páginas do Facebook e contas de anúncio do usuário logado.",
        "auth": "Cookie panel_user",
        "query_params": {},
        "response": {
          "ok": true,
          "me": { "id": "string", "name": "string" },
          "pages": [{ "id": "string", "name": "string", "access_token": "string", "instagram_business_account": { "id": "string", "username": "string" } }],
          "ad_accounts": [{ "id": "string", "name": "string" }]
        }
      },
      {
        "status": "EXISTS",
        "method": "GET",
        "path": "/panel/pages",
        "description": "Lista todas as páginas conectadas no servidor (todas as sessões).",
        "auth": "Cookie panel_auth (usuário logado no painel)",
        "query_params": {},
        "response": {
          "ok": true,
          "pages": [{ "id": "string", "name": "string", "access_token": "string", "instagram_business_account": { "id": "string", "username": "string" } }]
        }
      }
    ]
  },

  "instagram": {
    "_note": "Fluxo Instagram Graph API via Meta Business. Imagem deve ser uma URL pública acessível pelo servidor do Facebook. Para imagens locais, use /panel/ad-builder-upload-image primeiro para obter uma URL pública.",

    "upload_image": {
      "status": "EXISTS",
      "method": "POST",
      "path": "/panel/ad-builder-upload-image",
      "description": "Faz upload de uma imagem local e retorna uma URL pública (usada depois nos endpoints de post).",
      "auth": "Cookie panel_auth",
      "content_type": "multipart/form-data",
      "form_fields": {
        "file": "arquivo de imagem (jpg/png/webp)"
      },
      "response": {
        "ok": true,
        "public_url": "https://cdn.exemplo.com/imagem.jpg",
        "path": "static/generated/arquivo.jpg"
      }
    },

    "step1_create_container": {
      "status": "EXISTS",
      "method": "POST",
      "path": "/meta/instagram-media/create",
      "description": "Passo 1 do fluxo Instagram: cria um container de mídia (imagem). Retorna creation_id. Para imagens simples, o status fica FINISHED em segundos. Para vídeos/reels, é assíncrono – faça poll do status antes de publicar.",
      "auth": "admin_token no body",
      "body": {
        "admin_token": "string – TOKEN_MASTER",
        "ig_user_id": "string – ID da conta Instagram Business",
        "access_token": "string – page access token da página vinculada",
        "image_url": "string – URL pública da imagem (mín 320x320, máx 8MB)",
        "caption": "string – legenda do post (até 2200 chars)"
      },
      "response": {
        "ok": true,
        "result": { "id": "string – creation_id / container_id" }
      }
    },

    "step2_check_container_status": {
      "status": "EXISTS",
      "method": "GET",
      "path": "/meta/instagram/container-status",
      "description": "Verifica o status do container. Espere status_code=FINISHED antes de publicar. Para imagens, geralmente já vem FINISHED imediatamente. Para vídeos, pode levar minutos.",
      "auth": "Nenhuma (usa sessão interna do servidor)",
      "query_params": {
        "container_id": "string – creation_id retornado no passo 1",
        "ig_user_id": "string – ID da conta Instagram (opcional se page_id passado)",
        "access_token": "string – page access token (opcional se page_id passado)",
        "page_id": "string – page_id (alternativa ao ig_user_id+access_token)",
        "username": "string – username Instagram (alternativa)"
      },
      "response": {
        "ok": true,
        "container_id": "string",
        "status_code": "FINISHED | IN_PROGRESS | EXPIRED | ERROR",
        "status": "string"
      }
    },

    "step3_publish": {
      "status": "EXISTS",
      "method": "POST",
      "path": "/meta/instagram-media/publish",
      "description": "Passo 3: publica o container validado. Use somente após status_code=FINISHED.",
      "auth": "admin_token no body",
      "body": {
        "admin_token": "string – TOKEN_MASTER",
        "ig_user_id": "string – ID da conta Instagram Business",
        "access_token": "string – page access token",
        "creation_id": "string – container_id do passo 1"
      },
      "response": {
        "ok": true,
        "result": { "id": "string – ID do post publicado no Instagram" }
      }
    },

    "step3_alternative_schedule": {
      "status": "EXISTS",
      "method": "POST",
      "path": "/schedule/post/add",
      "description": "Alternativa ao publish imediato: agenda o post para ser publicado em um horário específico. O servidor executa os posts agendados automaticamente.",
      "auth": "admin_token no body",
      "body": {
        "admin_token": "string – TOKEN_MASTER",
        "ig_user_id": "string – ID da conta Instagram Business",
        "access_token": "string – page access token",
        "image_url": "string – URL pública da imagem",
        "caption": "string – legenda",
        "scheduled_at": "number – Unix timestamp do momento de publicação",
        "page_id": "string – opcional",
        "ig_username": "string – opcional",
        "page_name": "string – opcional"
      },
      "response": {
        "ok": true,
        "post": {
          "id": "string",
          "status": "scheduled",
          "scheduled_at": "number",
          "image_url": "string",
          "caption": "string"
        }
      }
    },

    "publish_container_alt": {
      "status": "EXISTS",
      "method": "POST",
      "path": "/meta/instagram/publish-container",
      "description": "Alternativa ao /meta/instagram-media/publish. Aceita ig_user_id+access_token OU page_id diretamente.",
      "auth": "Nenhuma (usa sessão interna ou ig_user_id+access_token no body)",
      "body": {
        "container_id": "string – creation_id",
        "ig_user_id": "string – opcional se page_id passado",
        "access_token": "string – opcional se page_id passado",
        "page_id": "string – alternativa a ig_user_id+access_token"
      },
      "response": {
        "ok": true,
        "publish_result": { "id": "string – ID do post publicado" }
      }
    },

    "carousel": {
      "status": "EXISTS",
      "method": "POST",
      "path": "/meta/instagram/carousel",
      "description": "Publica um carrossel com 2 a 10 imagens em uma única chamada (cria todos os containers + publica).",
      "auth": "Nenhuma (usa sessão interna ou ig_user_id+access_token no body)",
      "body": {
        "image_urls": ["string", "string"],
        "caption": "string",
        "ig_user_id": "string – opcional",
        "access_token": "string – opcional",
        "page_id": "string – opcional"
      },
      "response": {
        "ok": true,
        "items": [{ "id": "string" }],
        "container": { "id": "string" },
        "publish_result": { "id": "string" }
      }
    },

    "story": {
      "status": "EXISTS",
      "method": "POST",
      "path": "/meta/instagram/story",
      "description": "Publica um Story no Instagram (imagem).",
      "auth": "Nenhuma (usa sessão interna ou ig_user_id+access_token no body)",
      "body": {
        "image_url": "string",
        "ig_user_id": "string – opcional",
        "access_token": "string – opcional",
        "page_id": "string – opcional"
      },
      "response": {
        "ok": true,
        "container": { "id": "string" },
        "publish_result": { "id": "string" }
      }
    },

    "reel": {
      "status": "EXISTS",
      "method": "POST",
      "path": "/meta/instagram/reel",
      "description": "Cria um container de Reel (vídeo). Async – após criar, faça poll do container-status até FINISHED, depois chame publish-container.",
      "auth": "Nenhuma (usa sessão interna ou ig_user_id+access_token no body)",
      "body": {
        "video_url": "string – URL pública do vídeo .mp4",
        "caption": "string – opcional",
        "share_to_feed": "boolean – opcional, default true",
        "ig_user_id": "string – opcional",
        "access_token": "string – opcional",
        "page_id": "string – opcional"
      },
      "response": {
        "ok": true,
        "container": { "id": "string – use para poll e depois publicar" }
      }
    },

    "list_scheduled": {
      "status": "EXISTS",
      "method": "GET",
      "path": "/schedule/posts",
      "description": "Lista posts agendados/publicados.",
      "auth": "Nenhuma",
      "query_params": {
        "status": "string – 'scheduled' | 'published' | 'failed' (opcional)",
        "page_id": "string – filtrar por página (opcional)",
        "ig_user_id": "string – filtrar por conta IG (opcional)"
      },
      "response": {
        "ok": true,
        "posts": [{ "id": "string", "status": "string", "scheduled_at": "number", "image_url": "string", "caption": "string" }]
      }
    },

    "publish_now_scheduled": {
      "status": "EXISTS",
      "method": "POST",
      "path": "/schedule/post/publish-now",
      "description": "Força a publicação imediata de um post agendado pelo ID.",
      "auth": "Cookie panel_auth",
      "body": { "post_id": "string" },
      "response": { "ok": true }
    },

    "delete_scheduled": {
      "status": "EXISTS",
      "method": "POST",
      "path": "/schedule/post/delete",
      "description": "Remove um post agendado.",
      "auth": "Cookie panel_auth",
      "body": { "post_id": "string" },
      "response": { "ok": true }
    },

    "insights": {
      "status": "EXISTS",
      "method": "GET",
      "path": "/meta/instagram-insights",
      "description": "Métricas da conta Instagram (alcance, impressões, etc).",
      "auth": "Nenhuma (usa sessão interna)",
      "query_params": {
        "ig_user_id": "string – ID da conta IG",
        "page_id": "string – alternativa",
        "metrics": "string – ex: 'reach,impressions,profile_views' (opcional, usa padrão se vazio)",
        "period": "string – 'day' | 'week' | 'days_28' | 'month' (opcional)",
        "since": "string – Unix timestamp início (opcional)",
        "until": "string – Unix timestamp fim (opcional)"
      },
      "response": {
        "ok": true,
        "data": { "reach": "number", "impressions": "number", "profile_views": "number" }
      }
    }
  },

