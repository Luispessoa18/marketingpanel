  "ads_trafego_pago": {
    "_note": "Tráfego pago via Meta Ads API. A maioria exige cookies de sessão (panel_auth). Para uso externo, o workaround é passar ig_user_id + access_token ou usar o admin_token onde disponível.",

    "list_campaigns_with_kpis": {
      "status": "EXISTS",
      "method": "GET",
      "path": "/meta/ad-performance-tree",
      "description": "Retorna a árvore completa: Campanhas → Conjuntos → Anúncios, com KPIs de cada nível (spend, CTR, CPC, CPM, impressões, cliques, leads).",
      "auth": "Cookie panel_auth OU panel_user",
      "query_params": {
        "ad_account_id": "string – ID da conta de anúncios (ex: 'act_123456')",
        "date_preset": "string – 'last_7d' | 'last_14d' | 'last_30d' | 'last_90d' | 'this_month' | 'last_month'",
        "since": "string – data ISO 'YYYY-MM-DD' (alternativa a date_preset)",
        "until": "string – data ISO 'YYYY-MM-DD' (alternativa a date_preset)",
        "limit": "string – máx de campanhas, default '250'"
      },
      "response": {
        "ok": true,
        "campaigns": [{
          "campaign": { "id": "string", "name": "string", "objective": "string", "status": "string", "effective_status": "string" },
          "metrics": { "spend": "string", "clicks": "string", "impressions": "string", "ctr": "string", "cpc": "string", "cpm": "string", "leads": "string" },
          "adsets": [{
            "adset": { "id": "string", "name": "string" },
            "metrics": {},
            "ads": [{ "ad": { "id": "string", "name": "string" }, "metrics": {} }]
          }]
        }],
        "summary": { "spend": "string", "campaigns_count": "number", "active_count": "number" }
      }
    },

    "ai_report": {
      "status": "EXISTS",
      "method": "GET",
      "path": "/panel/ads/report",
      "description": "Relatório completo de anúncios com análise IA (melhor campanha, público ideal, criativo vencedor, sugestões).",
      "auth": "Cookie panel_auth",
      "query_params": {
        "ad_account_id": "string",
        "date_preset": "string – mesmo formato de /meta/ad-performance-tree"
      },
      "response": {
        "ok": true,
        "report": {
          "campaigns": [{}],
          "adsets": [{}],
          "ads": [{}]
        },
        "report_summary": { "active_campaigns": "number", "paused_campaigns": "number", "total_spend": "string" },
        "ai_summary": "string – análise em texto gerada por IA"
      }
    },

    "create_campaign": {
      "status": "EXISTS",
      "method": "POST",
      "path": "/meta/ad-drafts/create-campaign",
      "description": "Cria uma campanha completa em modo PAUSED (rascunho): campanha + conjunto de anúncios + criativo + anúncio. Ative depois com /meta/ad-drafts/activate.",
      "auth": "Cookie panel_auth",
      "body": {
        "ad_account_id": "string – ex: 'act_123456'",
        "campaign_name": "string",
        "adset_name": "string",
        "daily_budget": "string – em centavos (ex: '5000' = R$50,00)",
        "objective": "string – 'OUTCOME_LEADS' | 'OUTCOME_TRAFFIC' | 'OUTCOME_SALES' | 'OUTCOME_ENGAGEMENT'",
        "page_id": "string – ID da Página Facebook",
        "instagram_actor_id": "string – ID da conta Instagram (opcional)",
        "targeting": {
          "age_min": "number",
          "age_max": "number",
          "genders": [2],
          "geo_locations": {
            "countries": [{ "country_code": "BR" }],
            "cities": [{ "name": "São Paulo" }]
          },
          "flexible_spec": [{ "interests": [{ "name": "string", "id": "string" }] }]
        },
        "message": "string – texto do anúncio (opcional)",
        "headline": "string – título do anúncio (opcional)",
        "link": "string – URL de destino (opcional)",
        "image_url": "string – URL da imagem do criativo (opcional)",
        "call_to_action_type": "string – 'SIGN_UP' | 'LEARN_MORE' | 'SHOP_NOW' | 'CONTACT_US' (opcional)",
        "optimization_goal": "string – 'LEAD_GENERATION' | 'LINK_CLICKS' | 'OFFSITE_CONVERSIONS' (opcional)",
        "billing_event": "string – 'IMPRESSIONS' (opcional)",
        "promoted_object": {
          "_note": "Usar para OUTCOME_LEADS com formulário",
          "page_id": "string",
          "lead_ads_custom_conversion": "string – form_id"
        }
      },
      "response": {
        "ok": true,
        "campaign": { "id": "string", "name": "string" },
        "adset": { "id": "string" },
        "creative": { "id": "string" },
        "ad": { "id": "string" }
      }
    },

