  "usage_examples": {
    "instagram_post_flow": {
      "_title": "Fluxo completo para postar no Instagram",
      "steps": [
        {
          "step": 1,
          "action": "Criar container de mídia",
          "call": "POST /meta/instagram-media/create",
          "body": {
            "admin_token": "SEU_TOKEN_MASTER",
            "ig_user_id": "123456789",
            "access_token": "EAABwzLixnjY...",
            "image_url": "https://cdn.exemplo.com/imagem.jpg",
            "caption": "Meu post #hashtag"
          },
          "save": "creation_id = response.result.id"
        },
        {
          "step": 2,
          "action": "Verificar status (aguardar FINISHED)",
          "call": "GET /meta/instagram/container-status?container_id=CREATION_ID&ig_user_id=123456789&access_token=TOKEN",
          "wait_for": "response.status_code === 'FINISHED'",
          "poll_interval_ms": 2000
        },
        {
          "step": 3,
          "action": "Publicar",
          "call": "POST /meta/instagram-media/publish",
          "body": {
            "admin_token": "SEU_TOKEN_MASTER",
            "ig_user_id": "123456789",
            "access_token": "EAABwzLixnjY...",
            "creation_id": "CREATION_ID_DO_PASSO_1"
          },
          "result": "response.result.id = ID do post publicado"
        }
      ]
    },

    "instagram_schedule_flow": {
      "_title": "Fluxo para agendar post no Instagram",
      "steps": [
        {
          "step": 1,
          "action": "Agendar diretamente (sem precisar criar container antes)",
          "call": "POST /schedule/post/add",
          "body": {
            "admin_token": "SEU_TOKEN_MASTER",
            "ig_user_id": "123456789",
            "access_token": "EAABwzLixnjY...",
            "image_url": "https://cdn.exemplo.com/imagem.jpg",
            "caption": "Post agendado #exemplo",
            "scheduled_at": 1748822400,
            "page_id": "PAGE_ID",
            "ig_username": "minha_conta"
          },
          "note": "O servidor cria o container e publica automaticamente no horário agendado"
        }
      ]
    },

    "facebook_post_flow": {
      "_title": "Postar no Facebook (mais simples – uma chamada só)",
      "steps": [
        {
          "step": 1,
          "action": "Post com foto",
          "call": "POST /meta/facebook/photo",
          "body": {
            "page_id": "ID_DA_PAGINA",
            "image_url": "https://cdn.exemplo.com/imagem.jpg",
            "caption": "Descrição do post",
            "published": true
          }
        }
      ]
    },

    "get_campaign_kpis": {
      "_title": "Puxar KPIs de campanhas (Tráfego Pago)",
      "call": "GET /meta/ad-performance-tree?ad_account_id=act_123456&date_preset=last_7d",
      "auth": "Requer cookie de sessão panel_auth",
      "note": "Retorna campanhas com spend, CTR, CPC, impressões, cliques e leads em cada nível"
    },

    "create_lead_campaign": {
      "_title": "Criar campanha de captação de leads",
      "call": "POST /meta/ad-drafts/create-campaign",
      "body": {
        "ad_account_id": "act_123456",
        "campaign_name": "Captação Leads – Junho 2026",
        "adset_name": "Público SP 25-45",
        "daily_budget": "5000",
        "objective": "OUTCOME_LEADS",
        "page_id": "ID_DA_PAGINA",
        "targeting": {
          "age_min": 25,
          "age_max": 45,
          "geo_locations": { "cities": [{ "name": "São Paulo" }] },
          "flexible_spec": [{ "interests": [{ "name": "Imóveis", "id": "6003263742899" }] }]
        },
        "message": "Garanta sua vaga! Preencha o formulário.",
        "call_to_action_type": "SIGN_UP",
        "optimization_goal": "LEAD_GENERATION",
        "billing_event": "IMPRESSIONS",
        "promoted_object": {
          "page_id": "ID_DA_PAGINA",
          "lead_ads_custom_conversion": "FORM_ID"
        }
      },
      "then": "Chame POST /meta/ad-drafts/activate com campaign_id para ativar"
    }
  }
